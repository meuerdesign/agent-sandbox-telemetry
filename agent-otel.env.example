# Copy to agent-otel.env, set the token, then install on an agent box as
#   /opt/agent/secrets/otel.env
# run-agent.sh detects it and turns telemetry on. agent-otel.env is gitignored.
#   cp agent-otel.env.example agent-otel.env

CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Must match your collector's DOMAIN:
OTEL_EXPORTER_OTLP_ENDPOINT=https://telemetry.example.com
# Must match telemetry/.env INGEST_TOKEN:
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer REPLACE_WITH_INGEST_TOKEN
OTEL_METRIC_EXPORT_INTERVAL=60000
OTEL_LOGS_EXPORT_INTERVAL=5000
OTEL_LOG_USER_PROMPTS=0
OTEL_LOG_TOOL_DETAILS=1
OTEL_RESOURCE_ATTRIBUTES=service.name=agent-sandbox
