# Copy to .env and fill in. .env is gitignored (never commit real values).
#   cp .env.example .env

# Bearer token the agent boxes must send to push telemetry.
# Generate:  openssl rand -hex 32
INGEST_TOKEN=

# Grafana admin password (user is "admin").
# Generate:  openssl rand -base64 18 | tr -d '/+=' | head -c 24
GRAFANA_ADMIN_PASSWORD=

# Public hostname for the collector (DNS A-record -> the VPS IP).
DOMAIN=telemetry.example.com

# Optional: email for Let's Encrypt expiry notices (leave blank to skip).
ACME_EMAIL=
